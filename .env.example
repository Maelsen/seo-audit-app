# Anthropic API
ANTHROPIC_API_KEY=

# Google PageSpeed Insights (optional, ohne Key geringere Rate Limits)
GOOGLE_PAGESPEED_API_KEY=

# Basic Auth (schuetzt die gesamte Seite)
BASIC_AUTH_USER=vasileios
BASIC_AUTH_PASS=

# Agent git-push (auf Railway=1, lokal leer lassen)
ENABLE_GIT_SYNC=
GITHUB_PAT=
GITHUB_REPO=
GIT_AUTHOR_NAME=Agent
GIT_AUTHOR_EMAIL=agent@local

# Next.js Mode (bleibt development, auch auf Railway, wegen HMR fuer Live-Agent-Edits)
NODE_ENV=development
